# ─────────────────────────────────────────────────────────────────────────────
# Secrets — never commit these
# ─────────────────────────────────────────────────────────────────────────────
.env

# ─────────────────────────────────────────────────────────────────────────────
# Generated data — large files produced by the pipeline at runtime
# ─────────────────────────────────────────────────────────────────────────────
data/raw/*.json
data/normalized/*.json
logs/*.log

# ─────────────────────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

# ─────────────────────────────────────────────────────────────────────────────
# Node / Next.js (frontend)
# ─────────────────────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.env.local

# ─────────────────────────────────────────────────────────────────────────────
# Python test cache
# ─────────────────────────────────────────────────────────────────────────────
.pytest_cache/

# ─────────────────────────────────────────────────────────────────────────────
# macOS
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
