# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# ── OpenAI ────────────────────────────────────────────────
# Required for Phase 5 (embedder) and Phase 6 (LLM generation).
OPENAI_API_KEY=sk-...

# ── Vector Store ──────────────────────────────────────────
# Path where ChromaDB persists its data.
# Default: ./vector_store/chroma_db  (relative to project root)
CHROMA_DB_PATH=./vector_store/chroma_db

# ── Logging ───────────────────────────────────────────────
# Set to DEBUG for verbose output during local development.
LOG_LEVEL=INFO
